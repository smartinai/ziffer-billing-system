# Copy to /etc/ziffer-backup.env, set owner root:root and mode 600.
RESTIC_REPOSITORY=s3:https://s3.example.invalid/ziffer-production-backups
RESTIC_PASSWORD_FILE=/etc/ziffer-restic-password
AWS_ACCESS_KEY_ID=replace-with-restricted-object-storage-key
AWS_SECRET_ACCESS_KEY=replace-with-restricted-object-storage-secret
