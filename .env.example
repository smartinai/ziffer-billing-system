TEAMWORK_SITE_NAME=zifferlu.eu
TEAMWORK_API_KEY=replace-with-teamwork-api-key
TEAMWORK_AUTH_MODE=basic
# npm run db:local:start uses port 55432. Docker Compose uses port 5432.
DATABASE_URL=postgres://ziffer:ziffer_local_password@127.0.0.1:55432/ziffer_billing
DATABASE_SSL=false
DEFAULT_START_DATE=2026-01-01
DEFAULT_TIMEZONE=Europe/Amsterdam
DEFAULT_CURRENCY=EUR
SESSION_SECRET=replace-with-a-long-random-secret-before-vps
COOKIE_SECURE=false
TEAMWORK_MAX_PAGES=350
PORT=3000
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3000/api/xero/callback
XERO_RETURN_URL=http://127.0.0.1:3000/#billing-create-quote
XERO_SCOPES=offline_access accounting.invoices accounting.contacts.read accounting.settings.read
XERO_REFERENCE_SYNC_TTL_MS=21600000
XERO_STATUS_POLL_INTERVAL_MS=3600000
XERO_TENANT_ID=
XERO_TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-secret-before-vps
