{
  "name": "ziffer-billing-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1 --port 5173",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "build:demo": "node scripts/build-demo.mjs",
    "start": "node server/index.js",
    "test": "node --test",
    "test:visual": "node scripts/visual-check.mjs",
    "check": "npm run test && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "playwright": "^1.61.0",
    "vite": "^6.0.3"
  }
}
